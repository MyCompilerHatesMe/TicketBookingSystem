# =========================================================================
# Ticket Booking System - Unified Git Ignore
# =========================================================================

# -------------------------------------------------------------------------
# System & OS Files
# -------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.log
*.tmp
*.temp

# -------------------------------------------------------------------------
# IDEs & Editor Configuration
# -------------------------------------------------------------------------
.idea/
.vscode/
*.iml
*.iws
*.ipr
.project
.classpath
.factorypath
.settings/
.sts4-cache/
.apt_generated/
bin/
out/

# -------------------------------------------------------------------------
# Backend (Spring Boot + Gradle)
# -------------------------------------------------------------------------
backend/.gradle/
backend/build/
backend/out/
backend/bin/
backend/.settings/
backend/.project
backend/.classpath

# Avoid ignoring Gradle wrapper files
!**/gradle-wrapper.jar
!**/gradlew
!**/gradlew.bat

# -------------------------------------------------------------------------
# Frontend (React + Vite + Node)
# -------------------------------------------------------------------------
TicketSystemFront/node_modules/
TicketSystemFront/dist/
TicketSystemFront/build/
TicketSystemFront/.svelte-kit/
TicketSystemFront/.next/
TicketSystemFront/.nuxt/
TicketSystemFront/out/

# Node-specific ignore
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -------------------------------------------------------------------------
# Local Environment Variables & Secrets
# -------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.pem
*.key
